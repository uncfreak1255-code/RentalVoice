{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "invariant.d.ts",
    "index.ts"
  ],
  "exclude": ["node_modules", "backend/node_modules", "backend/generated", ".expo", "server"]
}
