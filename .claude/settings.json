{
  "permissions": {
    "defaultMode": "dontAsk",
    "deny": [
      "Edit(**/credentials*)",
      "Edit(**/secrets/**)",
      "Edit(**/*.p8)",
      "Edit(**/*.p12)",
      "Edit(**/*.key)",
      "Edit(**/*.mobileprovision)",
      "Edit(**/*.pem)",
      "Edit(**/package-lock.json)",
      "Edit(**/bun.lock)",
      "Edit(**/yarn.lock)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
