{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Read",
            "Edit",
            "Write",
            "Glob",
            "Grep",
            "WebFetch",
            "WebSearch",
            "Skill",
            "NotebookEdit",
            "Bash(npm run lint)",
            "Bash(npm run typecheck)",
            "Bash(npx jest *)",
            "Bash(git status *)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git add *)",
            "Bash(git branch *)",
            "Bash(git checkout *)",
            "Bash(ls *)",
            "Bash(mkdir *)",
            "Bash(cat *)",
            "Bash(head *)",
            "Bash(tail *)",
            "Bash(chmod *)",
            "Bash(bun run dev)",
            "Bash(bun run typecheck)"
        ],
        "deny": []
    },
    "hooks": {
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/stop-hook-git-check.sh"
                    }
                ]
            }
        ]
    },
    "plansDirectory": "./reports"
}
