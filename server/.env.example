# Rental Voice Server — Environment Variables
# Copy to .env and fill in values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ENV_CLASS=test
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_PROJECT_LABEL="Your Project Name"

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-hex-char-encryption-key

# AI Providers (managed mode)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Founder access (future live environment)
FOUNDER_EMAILS=sawyerbeck25@gmail.com
FOUNDER_PLAN_OVERRIDE=enterprise
FOUNDER_BILLING_BYPASS=true

# App
PORT=3001
NODE_ENV=development
