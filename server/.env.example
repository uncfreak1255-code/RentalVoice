# Rental Voice Server — Environment Variables
# Copy to .env and fill in values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ENV_CLASS=test
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_PROJECT_LABEL="Your Project Name"

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-hex-char-encryption-key

# AI proxy / managed mode
# Optional service token for /api/ai-proxy/* generation requests; account JWT auth is also accepted.
AI_PROXY_TOKEN=your-personal-proxy-token
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
# Legacy fallback still supported by server code during migration.
GOOGLE_API_KEY=

# Langfuse (optional — tracing no-ops without keys)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Founder access (future live environment)
FOUNDER_EMAILS=sawyerbeck25@gmail.com
FOUNDER_PLAN_OVERRIDE=enterprise
FOUNDER_BILLING_BYPASS=true

# Auto-provision (Hostaway → Supabase identity mapping)
AUTO_PROVISION_SECRET=your-auto-provision-secret

# App
PORT=3001
NODE_ENV=development
